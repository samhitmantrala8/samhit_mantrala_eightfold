# Optional provider keys. Do not commit real values.
OPENROUTER_KEYS=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
USE_LLM_EXTRACTOR=false

# Optional semantic skill matching through Hugging Face Inference API.
HF_API_TOKEN=
