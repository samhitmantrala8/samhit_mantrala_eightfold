# Optional provider key. Do not commit real values.
OPENROUTER_API_KEY=
OPENROUTER_KEY_1=
OPENROUTER_KEY_2=
OPENROUTER_KEY_3=
OPENROUTER_KEY_4=
OPENROUTER_KEY_5=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
USE_LLM_EXTRACTOR=false

# Optional Gemini pipeline for multilingual headings, evaluator loop, and compact LLMOps traces.
gem1=
gem2=
gem3=
gem4=
gem5=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_AGENT_MODEL=gemini-2.5-flash
USE_GEMINI_HYBRID=false
USE_AGENTIC_LLMOPS=false
AGENT_SCORE_THRESHOLD=8.5
AGENT_MAX_LOOPS=3

# Optional semantic skill matching through Hugging Face Inference API.
HF_API_TOKEN=
HF_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
USE_EMBEDDINGS=false

# Transformer defaults.
DEFAULT_PHONE_REGION=US
FETCH_GITHUB_REPOS=true
GITHUB_REPO_LIMIT=50
GITHUB_REPO_LANGUAGE_LIMIT=20
